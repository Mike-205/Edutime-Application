# Edutime environment variables. Copy to `.env` and fill real values.
# NEVER commit `.env`. Client reads SUPABASE_URL + SUPABASE_ANON_KEY via
# --dart-define or flutter_dotenv; service-role key is server-side only.

# --- Supabase (client-safe) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase (server-side only — Edge Functions / CI; never ship to client) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Firebase Cloud Messaging (push) ---
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVER_KEY=your-fcm-server-key

# --- Resend (transactional email) ---
RESEND_API_KEY=your-resend-api-key

# --- Edge Function webhook secret (DB webhook -> dispatch-fcm) ---
FCM_WEBHOOK_SECRET=generate-a-long-random-string